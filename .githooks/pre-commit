#!/usr/bin/env bash
# Regenerate derived catalog artifacts (manifest.json + README sections)
# whenever a SKILL.md change is staged, and re-stage the results so the
# commit is self-consistent. Skip silently if there's nothing to do.
#
# Installed per-clone with `make install-hooks`, which points
# core.hooksPath at .githooks/.

set -euo pipefail

staged=$(git diff --cached --name-only --diff-filter=ACMR || true)

if ! printf '%s\n' "$staged" | grep -qE '^skills/[^/]+/SKILL\.md$'; then
    exit 0
fi

echo "pre-commit: SKILL.md change detected — running make sync"

if ! make -s sync; then
    echo "pre-commit: make sync failed; aborting commit" >&2
    exit 1
fi

# Stage any regenerated artifacts. git add is a no-op when nothing changed,
# so this is safe whether or not sync actually modified a file.
git add manifest.json README.md
